{
  "name": "markshelf",
  "version": "0.2.2",
  "description": "Structured markdown viewer for git repositories",
  "license": "MIT",
  "author": "sksp.work",
  "homepage": "https://github.com/skspwork/markshelf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skspwork/markshelf.git"
  },
  "bugs": {
    "url": "https://github.com/skspwork/markshelf/issues"
  },
  "keywords": [
    "markdown",
    "viewer",
    "docs",
    "documentation",
    "git",
    "nextjs",
    "graph",
    "knowledge-base",
    "oss"
  ],
  "bin": {
    "markshelf": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    ".next/standalone",
    ".next/static",
    "public"
  ],
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build && node scripts/pack-static.mjs",
    "start": "next start",
    "docker:build": "docker build -t markshelf-base .",
    "docker:run": "node scripts/docker-run.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "cytoscape": "^3.33.2",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
