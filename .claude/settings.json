{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "implementer",
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck && npm run lint && npm test",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
